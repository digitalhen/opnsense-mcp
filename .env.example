# OPNsense connection (API key created in System > Access > Users > edit user > API keys)
OPNSENSE_URL=https://192.168.50.1
OPNSENSE_API_KEY=your-api-key
OPNSENSE_API_SECRET=your-api-secret
OPNSENSE_VERIFY_SSL=false

# Include plugin tools (true/false)
INCLUDE_PLUGINS=false

# OAuth password — used to authorize Claude.ai to access the MCP server
OAUTH_PASSWORD=your-oauth-password

# Public URL for OAuth (your Cloudflare Tunnel or reverse proxy hostname)
PUBLIC_URL=https://opnsense-mcp.yourdomain.com

# Token lifetime in hours (default: 24)
TOKEN_TTL_HOURS=24

# Server port
PORT=3100

# Log level (debug, info, warn, error)
LOG_LEVEL=info
